# Telegram BotFather se token lo.
TELEGRAM_BOT_TOKEN=123456789:replace_me

# Public channel ke liye @channelusername chalega.
# Private channel/group ke liye numeric id generally -100... hota hai.
TELEGRAM_CHAT_ID=@your_channel_username

# Default automation behaviour
MAX_ITEMS=15
LOOKBACK_HOURS=168
MIN_SCORE=4
DRY_RUN=false
DISABLE_WEB_PAGE_PREVIEW=true

# Optional: Google AI Studio / Gemini API polish.
# Empty rakho to normal template use hoga.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_ENABLED=true

# Optional paths
SOURCES_FILE=config/sources.json
STATE_FILE=data/posted_state.json
